# Generate using openssl rand -base64 32
AUTH_SECRET=""

PUBLIC_URL="https://www.yourdomain.com"

POSTGRES_PASSWORD="password"
POSTGRES_USER="postgres"
POSTGRES_DB_NAME="retrospend"

# if you're running Retrospend in a dev environment, you may want to change the address to localhost
DATABASE_URL="postgresql://postgres:password@postgres:5432/retrospend"
WORKER_URL="http://localhost:8080" # For local development

# Optional
# SHOW_LANDING_PAGE=true
# ENABLE_LEGAL_PAGES=true
# Generate using openssl rand -base64 32
WORKER_API_KEY="your-api-key-here"
LLM_MODEL="qwen2.5:7b"
IMPORTER_URL="http://localhost:8082"

# LLM Import Pipeline Settings (Optional)
# ENRICH_BATCH_SIZE=20        # Merchants per LLM enrichment batch (default: 20)
# ENRICH_CONCURRENCY=3        # Max parallel enrichment LLM calls (default: 3)
# PDF_CONCURRENCY=3           # Max parallel PDF chunk parsing LLM calls (default: 3)

# Import Queue Settings (Optional)
# Maximum number of concurrent import jobs that can be processed at once across all users
# Prevents server overload by limiting parallel processing (CSV parsing, PDF processing)
# Default: 3 (recommended for most deployments)
# Increase for high-capacity servers, decrease if experiencing resource issues
# MAX_CONCURRENT_IMPORT_JOBS=3

# SMTP Settings (Optional)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASSWORD="your-password"
# EMAIL_FROM="Retrospend <noreply@example.com>"

# Audit Log Privacy Mode (Optional)
# Controls what information is stored in security audit logs
# Options: "minimal" (default - no IP/user-agent), "anonymized" (recommended - anonymized IP), "full" (complete IP)
# AUDIT_PRIVACY_MODE=minimal  # Default - privacy-first, no IP addresses stored
# AUDIT_PRIVACY_MODE=anonymized  # Recommended - stores anonymized IPs (e.g., 192.168.1.0)
# AUDIT_PRIVACY_MODE=full  # Maximum security - stores complete IPs (requires GDPR compliance)

# Backup Settings (Optional)
# BACKUP_RETENTION_DAYS=30  # How many days to keep backup files (default: 30)
# BACKUP_CRON="0 3 * * *"  # Cron schedule for automatic backups (default: daily at 3 AM UTC)