# Generate using openssl rand -base64 32
AUTH_SECRET=""

PUBLIC_URL="https://www.yourdomain.com"
# TRUSTED_ORIGINS="https://tunnel.yourdomain.com,https://other.yourdomain.com"

POSTGRES_PASSWORD="password"
POSTGRES_USER="postgres"
POSTGRES_DB_NAME="retrospend"

# if you're running Retrospend in a dev environment, you may want to change the address to localhost
DATABASE_URL="postgresql://postgres:password@postgres:5432/retrospend"
SIDECAR_URL="http://localhost:8080"

# Optional
# SHOW_LANDING_PAGE=true
# ENABLE_LEGAL_PAGES=true
# Generate using openssl rand -base64 32
WORKER_API_KEY="your-api-key-here"
LLM_MODEL="qwen2.5:7b"
# Ollama endpoint for local AI (default: http://ollama:11434/api/generate for Docker container)
# Use http://host.docker.internal:11434/api/generate if Ollama runs on host instead of Docker
# OLLAMA_ENDPOINT="http://ollama:11434/api/generate"

# OpenRouter External AI (Optional)
# Enables external AI processing as an alternative to local Ollama
# Get an API key at https://openrouter.ai
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="qwen/qwen-2.5-7b-instruct"

# LLM Import Pipeline Settings (Optional)
# ENRICH_BATCH_SIZE=20        # Merchants per LLM enrichment batch (default: 20)
# ENRICH_CONCURRENCY=3        # Max parallel enrichment LLM calls (default: 3)
# PDF_CONCURRENCY=3           # Max parallel PDF chunk parsing LLM calls (default: 3)

# SMTP Settings (Optional)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASSWORD="your-password"
# EMAIL_FROM="Retrospend <noreply@example.com>"

# Unsubscribe Token Secret (Optional but recommended)
# Used to sign one-click unsubscribe links in notification emails.
# Generate using: openssl rand -base64 32
# Without this, unsubscribe links fall back to requiring login.
# UNSUBSCRIBE_SECRET=""

# Backup Settings (Optional)
# BACKUP_RETENTION_DAYS=30  # How many days to keep backup files (default: 30)
# BACKUP_CRON="0 3 * * *"  # Cron schedule for automatic backups (default: daily at 3 AM UTC)

# Upload Storage (for avatars, project images, receipts)
# In Docker: mounted as a named volume at /data/uploads (no config needed)
# For local dev: set to a local directory path
# UPLOAD_DIR=/data/uploads