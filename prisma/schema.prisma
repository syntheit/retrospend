generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-nixos"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                @id @default(cuid())
  name                  String                @db.VarChar(191)
  username              String                @unique @db.VarChar(64)
  email                 String                @unique @db.VarChar(255)
  emailVerified         Boolean               @default(false)
  image                 String?               @db.VarChar(2048)
  homeCurrency          String                @default("USD")
  categoryClickBehavior        CategoryClickBehavior        @default(toggle)
  role                         UserRole                     @default(USER)
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @default(now()) @updatedAt
  defaultCurrency       String                @default("USD")

  currencySymbolStyle         CurrencySymbolStyle           @default(standard)
  monthlyIncome               Decimal?                      @db.Decimal(10, 2)
  monthlyIncomeCurrency       String                        @default("USD")
  smartCurrencyFormatting     Boolean                       @default(true)
  defaultPrivacyMode          Boolean                       @default(false)
  fiscalMonthStartDay         Int                           @default(1)
  defaultExpenseDateBehavior  DefaultExpenseDateBehavior    @default(TODAY)
  accounts                Account[]
  assetAccounts           AssetAccount[]
  assetSnapshots          AssetSnapshot[]
  assetHistories          AssetHistory[]
  categories              Category[]
  favoriteExchangeRates   ExchangeRateFavorite[]
  expenses                Expense[]
  budgets                 Budget[]
  recurringTemplates      RecurringTemplate[]
  createdInviteCodes      InviteCode[]                  @relation("CreatedInviteCodes")
  usedInviteCodes         InviteCode[]                  @relation("UsedInviteCodes")
  sessions                Session[]
  pageSettings            UserPageSetting[]
  analyticsPreferences    AnalyticsCategoryPreference[]

  twoFactorEnabled Boolean?    @default(false)
  twofactors       TwoFactor[]
  eventLogs        EventLog[]
  importJobs       ImportJob[]

  aiMode            AiMode    @default(LOCAL)
  externalAiAllowed Boolean?
  aiUsages          AiUsage[]

  avatarPath              String?                  @db.VarChar(500)
  lastUsernameChangeAt    DateTime?

  // Pending email change (two-phase verification)
  pendingEmail            String?                  @db.VarChar(255)
  pendingEmailToken       String?                  @unique @db.VarChar(255)
  pendingEmailExpiresAt   DateTime?

  // Consent recording (GDPR / legal pages)
  consentedAt             DateTime?
  consentVersion          String?                  @db.VarChar(20)
  consentIp               String?                  @db.VarChar(45)

  feedback                Feedback[]
  usernameHistory         UsernameHistory[]
  createdShadowProfiles   ShadowProfile[]          @relation("CreatedShadowProfiles")
  claimedShadowProfiles   ShadowProfile[]          @relation("ClaimedShadowProfiles")
  createdProjects         Project[]
  paymentMethods          PaymentMethod[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.VarChar(255)
  userAgent String?  @db.VarChar(255)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @db.VarChar(191)
  providerId            String    @db.VarChar(64)
  userId                String
  accessToken           String?   @db.VarChar(2048)
  refreshToken          String?   @db.VarChar(2048)
  idToken               String?   @db.VarChar(2048)
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.VarChar(512)
  password              String?   @db.VarChar(255)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@unique([providerId, userId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @db.VarChar(255)
  value      String   @db.VarChar(255)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

model PasswordResetToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("password_reset_token")
}

model Expense {
  id            String        @id @default(cuid())
  userId        String
  title         String
  amount        Decimal       @db.Decimal(19, 8)
  currency      String
  date          DateTime
  categoryId    String?
  amountInUSD   Decimal       @db.Decimal(12, 2)
  exchangeRate  Decimal       @db.Decimal(10, 4)
  pricingSource String
  location      String?       @db.VarChar(191)
  description   String?       @db.VarChar(1000)
  status        ExpenseStatus @default(FINALIZED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Amortization fields
  isAmortizedParent Boolean   @default(false)
  isAmortizedChild  Boolean   @default(false)
  parentId          String?
  parent            Expense?  @relation("AmortizedExpenses", fields: [parentId], references: [id], onDelete: Cascade)
  children          Expense[] @relation("AmortizedExpenses")

  // Recurring subscription reference
  recurringTemplateId String?
  recurringTemplate   RecurringTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)

  // Analytics exclusion
  excludeFromAnalytics Boolean @default(false)

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([parentId])
  @@index([recurringTemplateId])
  @@index([userId, date, title, amount, currency])
  @@index([userId, status, date])
  @@index([userId, excludeFromAnalytics, date])
  @@index([userId, isAmortizedParent, date])
  @@map("expense")
}

model Category {
  id                   String                        @id @default(cuid())
  name                 String                        @db.VarChar(64)
  color                CategoryColor
  icon                 String?                       @db.VarChar(32)
  isFixed              Boolean                       @default(false)
  excludeByDefault     Boolean                       @default(false)
  userId               String
  user                 User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses             Expense[]
  budgets              Budget[]
  recurringTemplates   RecurringTemplate[]
  analyticsPreferences AnalyticsCategoryPreference[]
  sharedTransactions   SharedTransaction[]

  @@unique([name, userId])
  @@index([userId])
  @@map("category")
}

model RecurringTemplate {
  id            String             @id @default(cuid())
  userId        String
  name          String             @db.VarChar(191)
  amount        Decimal            @db.Decimal(10, 2)
  currency      String             @default("USD")
  categoryId    String?
  frequency     RecurringFrequency
  nextDueDate   DateTime
  websiteUrl    String?            @db.VarChar(512)
  paymentSource String?            @db.VarChar(191)
  autoPay       Boolean            @default(true)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  expenses Expense[]

  @@index([userId, nextDueDate])
  @@index([userId, isActive])
  @@map("recurring_template")
}

model Budget {
  id             String     @id @default(cuid())
  amount         Decimal    @db.Decimal(10, 2)
  currency       String     @default("USD")
  period         DateTime
  isRollover     Boolean    @default(false)
  rolloverAmount Decimal    @default(0) @db.Decimal(10, 2)
  pegToActual    Boolean    @default(false)
  type           BudgetType @default(FIXED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  userId         String
  categoryId     String?
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, categoryId, period])
  @@index([userId, period])
  @@map("budget")
}

model ExchangeRate {
  id        String                 @id @default(cuid())
  date      DateTime
  currency  String
  type      String                 @default("official") @db.VarChar(32)
  rate      Decimal                @db.Decimal(18, 6)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  favorites ExchangeRateFavorite[]

  @@unique([date, currency, type])
  @@index([currency, type, date])
  @@map("exchange_rate")
}

model ExchangeRateFavorite {
  id             String       @id @default(cuid())
  userId         String
  exchangeRateId String
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exchangeRateId])
  @@unique([userId, order])
  @@map("exchange_rate_favorite")
}

model AssetAccount {
  id               String          @id @default(cuid())
  userId           String
  name             String
  type             AssetType
  currency         String
  balance          Decimal         @db.Decimal(19, 8)
  exchangeRate     Decimal?        @db.Decimal(18, 6)
  exchangeRateType String?         @db.VarChar(32)
  isLiquid         Boolean         @default(false)
  interestRate     Float?
  minimumPayment   Decimal?        @db.Decimal(10, 2)
  dueDate          Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots        AssetSnapshot[]
  history          AssetHistory[]

  @@index([userId])
  @@map("asset_account")
}

model AssetSnapshot {
  id           String       @id @default(cuid())
  accountId    String
  userId       String
  date         DateTime
  balance      Decimal      @db.Decimal(19, 8)
  balanceInUSD Decimal      @db.Decimal(12, 2)
  account      AssetAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@index([userId])
  @@index([userId, date])
  @@map("asset_snapshot")
}

model AssetHistory {
  id         String       @id @default(cuid())
  assetId    String
  userId     String
  balance    Decimal      @db.Decimal(19, 8)
  recordedAt DateTime     @default(now())
  asset      AssetAccount @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assetId, recordedAt])
  @@index([userId])
  @@map("asset_history")
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  isActive    Boolean   @default(true)
  usedAt      DateTime?
  expiresAt   DateTime?
  createdById String
  usedById    String?
  createdAt   DateTime  @default(now())
  createdBy   User      @relation("CreatedInviteCodes", fields: [createdById], references: [id], onDelete: Cascade)
  usedBy      User?     @relation("UsedInviteCodes", fields: [usedById], references: [id])

  @@map("invite_code")
}

model AppSettings {
  id                             String   @id @default("app_settings_singleton")
  inviteOnlyEnabled              Boolean  @default(false)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  allowAllUsersToGenerateInvites Boolean  @default(false)
  enableEmail                    Boolean  @default(true)

  defaultAiMode               AiMode               @default(LOCAL)
  externalAiAccessMode        ExternalAiAccessMode @default(WHITELIST)
  monthlyAiTokenQuota         Int                  @default(2000000)
  monthlyLocalAiTokenQuota    Int                  @default(10000000)
  monthlyExternalAiTokenQuota Int                  @default(2000000)

  auditPrivacyMode       AuditPrivacyMode     @default(MINIMAL)
  maxConcurrentImportJobs Int                 @default(3)
  enableFeedback         Boolean              @default(false)

  @@map("app_settings")
}

enum AuditPrivacyMode {
  MINIMAL
  ANONYMIZED
  FULL
}

enum CategoryColor {
  emerald
  blue
  sky
  cyan
  teal
  orange
  amber
  violet
  pink
  fuchsia
  indigo
  slate
  zinc
  lime
  neutral
  gray
  purple
  yellow
  stone
  rose
  red
}

enum CategoryClickBehavior {
  navigate
  toggle
}

enum CurrencySymbolStyle {
  native
  standard
}

enum UserRole {
  USER
  ADMIN
}

enum ExpenseStatus {
  DRAFT
  FINALIZED
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum AssetType {
  CASH
  INVESTMENT
  CRYPTO
  REAL_ESTATE
  VEHICLE
  LIABILITY_LOAN
  LIABILITY_CREDIT_CARD
  LIABILITY_MORTGAGE
}

enum BudgetType {
  FIXED
  PEG_TO_ACTUAL
  PEG_TO_LAST_MONTH
}

enum DefaultExpenseDateBehavior {
  TODAY
  LAST_USED
}

enum Page {
  DASHBOARD
  BUDGET
  ANALYTICS
  WEALTH
  EXCHANGE_RATES
  SETTINGS
  TABLE
  ACCOUNT
  INVITE_CODES
  ADMIN
  EXPENSE
  PROFILE
}

enum EventType {
  FAILED_LOGIN
  SUCCESSFUL_LOGIN
  PASSWORD_RESET
  PASSWORD_CHANGED
  ACCOUNT_CREATED
  ACCOUNT_DELETED
  ACCOUNT_ENABLED
  ACCOUNT_DISABLED
  INVITE_USED
  INVITE_CREATED
  EMAIL_VERIFIED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  SETTINGS_UPDATED
  USER_UPDATED
  USERNAME_CHANGED
  EXPENSE_IMPORT
  ADMIN_RESET_LINK_GENERATED
  ADMIN_AI_ACCESS_CHANGED
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGE_CONFIRMED
  EMAIL_CHANGE_REVERTED
  GUEST_UPGRADED
}

enum ImportJobStatus {
  QUEUED
  PROCESSING
  READY_FOR_REVIEW
  REVIEWING
  COMPLETED
  FAILED
  CANCELLED
}

enum ImportJobType {
  CSV
  BANK_STATEMENT
}

enum AiMode {
  LOCAL
  EXTERNAL
}

enum ExternalAiAccessMode {
  WHITELIST
  BLACKLIST
}

model UserPageSetting {
  id       String @id @default(cuid())
  userId   String
  page     Page
  settings Json
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, page])
  @@map("user_page_setting")
}

model AnalyticsCategoryPreference {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  isFlexible Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@map("analytics_category_preference")
}

model SystemStatus {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_status")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model EventLog {
  id        String    @id @default(cuid())
  timestamp DateTime  @default(now())
  eventType EventType
  userId    String?
  ipAddress String?   @db.VarChar(255)
  userAgent String?   @db.VarChar(255)
  metadata  Json?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([userId])
  @@index([eventType])
  @@index([eventType, timestamp])
  @@map("event_log")
}

model ImportJob {
  id     String          @id @default(cuid())
  userId String
  status ImportJobStatus @default(QUEUED)
  type   ImportJobType

  // File metadata
  fileName String
  fileSize Int
  fileType String  // "csv" | "pdf"
  fileData String? @db.Text // Base64 encoded file data (cleared after processing)

  // Processing results
  transactions Json?   // ImporterTransaction[] when processed
  warnings     Json?   // string[] from importer
  errorMessage String? @db.VarChar(1000)

  // Result metadata
  totalTransactions Int  @default(0)
  importedCount     Int? // After final import
  skippedDuplicates Int? // After final import

  // Timestamps for each stage
  createdAt        DateTime  @default(now())
  processingAt     DateTime?
  readyForReviewAt DateTime?
  reviewingAt      DateTime?
  completedAt      DateTime?
  failedAt         DateTime?

  // Progress tracking (for bank statements)
  progressPercent Float?
  statusMessage   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("import_job")
}

model AiUsage {
  id                 String   @id @default(cuid())
  userId             String
  yearMonth          String   @db.VarChar(7)
  tokensUsed         Int      @default(0)
  localTokensUsed    Int      @default(0)
  externalTokensUsed Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, yearMonth])
  @@index([userId])
  @@map("ai_usage")
}

// ============================================================
// Shared Expenses Models
// ============================================================

model ShadowProfile {
  id          String    @id @default(cuid())
  createdById String
  name        String    @db.VarChar(191)
  email       String?   @db.VarChar(255)
  phone       String?   @db.VarChar(64)
  claimedById String?
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  createdBy User  @relation("CreatedShadowProfiles", fields: [createdById], references: [id], onDelete: Cascade)
  claimedBy User? @relation("ClaimedShadowProfiles", fields: [claimedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([email])
  @@map("shadow_profile")
}

model GuestSession {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(191)
  email        String   @db.VarChar(255)
  magicLinkId  String
  projectId    String
  sessionToken String   @unique @db.VarChar(255)
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  @@index([email])
  @@index([projectId])
  @@map("guest_session")
}

model SharedTransaction {
  id              String    @id @default(cuid())
  description     String    @db.VarChar(500)
  amount          Decimal   @db.Decimal(19, 8)
  currency        String
  date            DateTime
  categoryId      String?
  splitMode       SplitMode @default(EQUAL)
  notes           String?   @db.Text
  receiptUrl      String?   @db.VarChar(2048)
  isLocked        Boolean   @default(false)

  paidByType      ParticipantType
  paidById        String

  createdByType   ParticipantType
  createdById     String

  projectId       String?
  billingPeriodId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  category        Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  project         Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  billingPeriod   BillingPeriod?     @relation(fields: [billingPeriodId], references: [id], onDelete: SetNull)
  splitParticipants SplitParticipant[]

  @@index([paidByType, paidById])
  @@index([createdByType, createdById])
  @@index([projectId])
  @@index([billingPeriodId])
  @@index([billingPeriodId, date])
  @@index([projectId, date])
  @@index([categoryId])
  @@map("shared_transaction")
}

model SplitParticipant {
  id                 String             @id @default(cuid())
  transactionId      String
  participantType    ParticipantType
  participantId      String
  shareAmount        Decimal            @db.Decimal(19, 8)
  sharePercentage    Decimal?           @db.Decimal(5, 2)
  shareUnits         Int?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  rejectionReason    String?            @db.VarChar(500)
  hasUnseenChanges   Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt

  transaction SharedTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, participantType, participantId])
  @@index([transactionId])
  @@index([participantType, participantId])
  @@index([verificationStatus])
  @@index([participantType, participantId, transactionId])
  @@map("split_participant")
}

model Settlement {
  id                   String           @id @default(cuid())
  fromParticipantType  ParticipantType
  fromParticipantId    String
  toParticipantType    ParticipantType
  toParticipantId      String
  amount               Decimal          @db.Decimal(19, 8)
  currency             String
  convertedAmount      Decimal?         @db.Decimal(19, 8)
  convertedCurrency    String?
  exchangeRateUsed     Decimal?         @db.Decimal(18, 6)
  paymentMethod        String?          @db.VarChar(191)
  billingPeriodId      String?
  status               SettlementStatus @default(PROPOSED)
  confirmedByPayer     Boolean          @default(false)
  confirmedByPayee     Boolean          @default(false)
  note                 String?          @db.VarChar(500)
  initiatedAt          DateTime         @default(now())
  settledAt            DateTime?
  rejectedAt           DateTime?
  rejectedReason       String?          @db.VarChar(500)
  reminderSentAt       DateTime?
  reminderCount        Int              @default(0)
  autoConfirmedReason  String?          @db.VarChar(200)

  @@index([fromParticipantType, fromParticipantId])
  @@index([toParticipantType, toParticipantId])
  @@index([billingPeriodId])
  @@index([status])
  @@index([status, fromParticipantType, fromParticipantId])
  @@index([status, toParticipantType, toParticipantId])
  @@map("settlement")
}

model AuditLogEntry {
  id         String          @id @default(cuid())
  timestamp  DateTime        @default(now())
  actorType  ParticipantType
  actorId    String
  action     AuditAction
  targetType AuditTargetType
  targetId   String
  changes    Json?
  context    Json?
  projectId  String?

  @@index([targetType, targetId])
  @@index([actorType, actorId])
  @@index([projectId])
  @@index([timestamp])
  @@index([action])
  @@map("audit_log_entry")
}

enum ParticipantType {
  user
  guest
  shadow
}

enum SplitMode {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

enum VerificationStatus {
  PENDING
  ACCEPTED
  REJECTED
  AUTO_ACCEPTED
}

enum SettlementStatus {
  PROPOSED
  CONFIRMED
  FINALIZED
  REJECTED
}

enum AuditAction {
  CREATED
  EDITED
  DELETED
  VERIFIED
  REJECTED
  AUTO_VERIFIED
  SETTLED
  PERIOD_CLOSED
  PARTICIPANT_ADDED
  PARTICIPANT_REMOVED
  ROLE_CHANGED
}

enum AuditTargetType {
  SHARED_TRANSACTION
  SETTLEMENT
  PROJECT
  BILLING_PERIOD
  SPLIT_PARTICIPANT
}

enum ProjectType {
  TRIP
  ONGOING
  SOLO
  ONE_TIME
  GENERAL
}

enum ProjectStatus {
  ACTIVE
  SETTLED
  ARCHIVED
}

enum ProjectVisibility {
  PRIVATE
  PUBLIC
}

enum ProjectRole {
  ORGANIZER
  EDITOR
  CONTRIBUTOR
  VIEWER
}

enum BillingCycleLength {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum BillingPeriodStatus {
  OPEN
  CLOSING
  SETTLED
  ARCHIVED
}

enum BillingClosePermission {
  ORGANIZER_ONLY
  ANY_PARTICIPANT
}

model Project {
  id                       String                 @id @default(cuid())
  name                     String                 @db.VarChar(191)
  description              String?                @db.VarChar(500)
  type                     ProjectType
  budgetAmount             Decimal?               @db.Decimal(19, 8)
  budgetCurrency           String?
  primaryCurrency          String                 @default("USD")
  createdById              String
  visibility               ProjectVisibility      @default(PRIVATE)
  status                   ProjectStatus          @default(ACTIVE)
  billingCycleLength       BillingCycleLength?
  billingCycleDays         Int?
  billingAutoClose         Boolean                @default(false)
  billingCloseReminderDays Int                    @default(3)
  billingClosePermission   BillingClosePermission @default(ORGANIZER_ONLY)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @default(now()) @updatedAt

  imagePath          String?             @db.VarChar(500)

  createdBy          User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  participants       ProjectParticipant[]
  billingPeriods     BillingPeriod[]
  magicLinks         MagicLink[]
  sharedTransactions SharedTransaction[]

  @@index([createdById])
  @@index([status])
  @@map("project")
}

model ProjectParticipant {
  id                    String          @id @default(cuid())
  projectId             String
  participantType       ParticipantType
  participantId         String
  role                  ProjectRole     @default(CONTRIBUTOR)
  joinedAt              DateTime        @default(now())
  excludeFromAnalytics  Boolean         @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, participantType, participantId])
  @@index([projectId])
  @@index([participantType, participantId])
  @@map("project_participant")
}

model BillingPeriod {
  id         String              @id @default(cuid())
  projectId  String
  label      String              @db.VarChar(100)
  startDate  DateTime
  endDate    DateTime
  status     BillingPeriodStatus @default(OPEN)
  closedById String?
  closedAt   DateTime?
  settledAt  DateTime?
  createdAt  DateTime            @default(now())

  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sharedTransactions SharedTransaction[]

  @@index([projectId])
  @@index([status])
  @@map("billing_period")
}

// ============================================================
// Payment Methods
// ============================================================

enum PaymentMethodVisibility {
  PUBLIC
  FRIENDS_ONLY
  PAYMENT_ONLY
}

model PaymentMethod {
  id         String                  @id @default(cuid())
  userId     String
  type       String                  @db.VarChar(50)
  label      String?                 @db.VarChar(100)
  identifier String?                 @db.VarChar(500)
  rank       Int
  visibility PaymentMethodVisibility @default(PAYMENT_ONLY)
  minAmount  Decimal?                @db.Decimal(19, 8)
  currency   String?                 @db.VarChar(10)
  network    String?                 @db.VarChar(50)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_method")
}

model MagicLink {
  id          String      @id @default(uuid())
  projectId   String
  roleGranted ProjectRole @default(CONTRIBUTOR)
  createdById String
  expiresAt   DateTime?
  maxUses     Int?
  useCount    Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("magic_link")
}

// ============================================================
// Notifications
// ============================================================

enum NotificationType {
  EXPENSE_SPLIT
  VERIFICATION_REQUEST
  EXPENSE_EDITED
  EXPENSE_DELETED
  SETTLEMENT_RECEIVED
  SETTLEMENT_CONFIRMED
  SETTLEMENT_REJECTED
  PERIOD_CLOSED
  PARTICIPANT_ADDED
  PAYMENT_REMINDER
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String           @db.VarChar(500)
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notification")
}

model NotificationPreference {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  inApp      Boolean          @default(true)
  email      Boolean          @default(false)
  digestMode Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_preference")
}

model UsernameHistory {
  id               String   @id @default(cuid())
  userId           String
  previousUsername  String   @unique @db.VarChar(64)
  changedAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([changedAt])
  @@map("username_history")
}

model Feedback {
  id            String   @id @default(cuid())
  userId        String
  message       String   @db.Text

  // Silent context (collected automatically)
  pageUrl       String
  userAgent     String?
  viewportSize  String?
  appVersion    String?

  // Admin management
  status        String   @default("unread")  // unread, read, archived
  adminNote     String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("feedback")
}
